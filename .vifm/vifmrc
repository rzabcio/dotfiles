colorscheme nord

" always show git log in preview of files inside some repository
au DirEnter '~/work/atl-scripts-*/**/*' setl previewprg='git log --color --pretty=short --stat --graph -- %c 2>&1'

nnoremap w :view<cr>

command! cmpinternal compare-cmd %a %S
command! cmp : if expand('%%c') == expand('%%f')
          \ |     echo expand('Comparing %%"c and %%"C:t ...')
          \ |     cmpinternal %c %C
          \ | else
          \ |     echo expand('Comparing files: %%"f ...')
          \ |     cmpinternal %f
          \ | endif
command! diff nvim -d %f %F
